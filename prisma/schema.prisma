  deliveryLocation                   OperationalLocation                       @relation("WalkingInventoryReservationDeliveryLocation", fields: [deliveryLocationId], references: [id], onDelete: Restrict, map: "WalkingInventoryReservation_delivery_location_fkey")
  lines                              WalkingInventoryReservationLine[]

  @@unique([clientId, idempotencyKey], map: "WalkingInventoryReservation_client_idempotency_key")
  @@index([quoteId, status], map: "WalkingInventoryReservation_quote_status_idx")
  @@index([expiresAt, status], map: "WalkingInventoryReservation_expiry_status_idx")
}

model WalkingInventoryReservationLine {
  id                       String                      @id @default(uuid()) @db.Uuid
  reservationId            String                      @db.Uuid
  inventoryNodeBalanceId   String                      @db.Uuid
  lineNumber               Int
  variantId                String                      @db.VarChar(160)

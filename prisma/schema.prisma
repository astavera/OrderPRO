  operationalLocation   OperationalLocation       @relation(fields: [operationalLocationId], references: [id], onDelete: Restrict, map: "WalkingCapacitySlot_location_fkey")
  holds                 WalkingCapacityHold[]

  @@unique([slotPolicyId, slotKey], map: "WalkingCapacitySlot_policy_key")
  @@index([operationalLocationId, startsAt, status], map: "WalkingCapacitySlot_location_start_idx")
}

model WalkingCapacityHold {
  id                      String                            @id @default(uuid()) @db.Uuid
  quoteId                 String                            @db.Uuid
  capacitySlotId          String                            @db.Uuid
  clientId                String                            @db.VarChar(120)
  idempotencyKey          String                            @db.VarChar(160)

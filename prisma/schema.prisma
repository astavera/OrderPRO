model WalkingInventoryReservation {
  id                                 String                                    @id @default(uuid()) @db.Uuid
  quoteId                            String                                    @db.Uuid
  capacityHoldId                     String                                    @unique(map: "WalkingInventoryReservation_capacity_hold_key") @db.Uuid
  clientId                           String                                    @db.VarChar(120)
  idempotencyKey                     String                                    @db.VarChar(160)
  requestHash                        String                                    @db.VarChar(80)
  correlationId                      String                                    @db.VarChar(120)
  status                             WalkingInventoryReservationStatus         @default(HELD)
  orderLocationId                    String                                    @db.Uuid
  deliveryLocationId                 String                                    @db.Uuid
  orderLocationExternalId            String                                    @db.VarChar(64)
  deliveryLocationExternalId         String                                    @db.VarChar(64)
  orderLocationDecisionCode          String                                    @db.VarChar(120)
  orderLocationDecisionVersion       String                                    @db.VarChar(120)
  inventoryAllocationStrategyId      String                                    @db.VarChar(120)
  inventoryAllocationStrategyVersion String                                    @db.VarChar(120)
  expiresAt                          DateTime
  confirmedOrderId                   String?                                   @db.VarChar(160)
  confirmedAt                        DateTime?
  releasedAt                         DateTime?
  releaseReason                      WalkingInventoryReservationReleaseReason?
  version                            Int                                       @default(1)
  createdAt                          DateTime                                  @default(now())
  updatedAt                          DateTime                                  @updatedAt

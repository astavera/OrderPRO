generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LocationType {
  WAREHOUSE
  STORE
}

enum RoleCode {
  OWNER
  OPERATIONS_ADMIN
  INVENTORY_CONTROLLER
  STORE_MANAGER
  STORE_STAFF
  WAREHOUSE_MANAGER
  WAREHOUSE_STAFF
  AUDITOR
}

enum MachineEnvironment {
  STAGING
  PRODUCTION
}

enum MachineAuthorizationStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  REVOKED
}

enum MachineCredentialProvider {
  AUTH0
}

enum MessageStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

enum ProductIdentifierType {
  UPC
  SKU
  GTIN
  INTERNAL
}

enum ContainerType {
  BOX
  ACTIVE_PICK_BIN
  TOTE
}

enum ContainerStatus {
  OPEN
  MANIFEST_CLOSED
  SEALED
  STAGED
  IN_TRANSIT
  RECEIVED_PENDING_VERIFICATION
  RECEIVED
  PUTAWAY
  ACTIVE
  QUARANTINED
  DAMAGED
  LOST
  EMPTY
  ARCHIVED
}

enum ManifestStatus {
  DRAFT
  CLOSED
  SUPERSEDED
}

enum SealAction {
  APPLIED
  BROKEN
}

enum InventoryAvailabilityState {
  UNAVAILABLE
  STAGED
  IN_TRANSIT
  RECEIVED_PENDING_ACTIVATION
  AVAILABLE_ONLINE
  RESERVED
  ALLOCATED
  PICKED
  SOLD
  QUARANTINED
  RETURN_STAGED
}

enum InventoryLedgerEventType {
  OPENING_BALANCE
  PACK_ACCEPTED
  PACK_CORRECTED
  STAGED
  DISPATCHED
  RECEIVED
  QUARANTINED
  PUTAWAY
  ACTIVATED
  DEACTIVATED
  MOVED
  RESERVED
  RESERVATION_RELEASED
  ALLOCATED
  PICKED
  SHORTAGE
  RETURNED
  COUNT_GAIN
  COUNT_LOSS
}

enum WalkingWeekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum WalkingAssignmentStrategy {
  FIXED
  NEAREST_WALKING_ROUTE
}

enum WalkingServiceMode {
  WALKING
}

enum WalkingZoneVersionStatus {
  DRAFT
  VALIDATED
  PUBLISHED
  ARCHIVED
}

enum DeliveryPolicyStatus {
  DRAFT
  DRAFT_INCOMPLETE
  VALIDATED
  PUBLISHED
  ARCHIVED
}

enum FeeServiceScope {
  GENERAL_LOCAL_DELIVERY
  BALLOON_DELIVERY
}

enum FulfillmentMode {
  PICKUP
  WALKING_LOCAL_DELIVERY
  WAREHOUSE_SHIPPING
  STORE_RETRIEVAL_SHIPPING
}

enum WalkingPublicationStatus {
  PUBLISHED
  ARCHIVED
}

enum FeeCalculationStrategy {
  WALKING_ROUTE_DISTANCE
}

enum FeePolicyEnvironment {
  STAGING
  PRODUCTION
}

enum WalkingQuoteReasonCode {
  INVALID_INPUT
  INVALID_ADDRESS
  GEOCODING_FAILED
  AMBIGUOUS_ADDRESS
  OUTSIDE_WALKING_ZONE
  NO_ACTIVE_ZONE
  SERVICE_DAY_UNAVAILABLE
  INVALID_ZONE_CONFIGURATION
  STORE_NOT_AVAILABLE
  ROUTE_METRICS_REQUIRED
  DISTANCE_EXCEEDED
  ROUTE_TIME_EXCEEDED
  MINIMUM_ORDER_NOT_MET
  FEE_POLICY_INCOMPLETE
  SLOT_POLICY_INCOMPLETE
  NO_AVAILABLE_SLOTS
  ELIGIBLE
  MANAGER_REVIEW
}

enum WalkingQuoteReasonCodeV4 {
  INVALID_INPUT
  INVALID_ADDRESS
  GEOCODING_FAILED
  AMBIGUOUS_ADDRESS
  OUTSIDE_WALKING_ZONE
  NO_ACTIVE_ZONE
  SERVICE_DAY_UNAVAILABLE
  INVALID_ZONE_CONFIGURATION
  STORE_NOT_AVAILABLE
  ROUTE_METRICS_REQUIRED
  DISTANCE_EXCEEDED
  ROUTE_TIME_EXCEEDED
  MINIMUM_ORDER_NOT_MET
  FEE_POLICY_INCOMPLETE
  SLOT_POLICY_INCOMPLETE
  NO_AVAILABLE_SLOTS
  ELIGIBLE
  MANAGER_REVIEW
  ADDRESS_NOT_IN_MANHATTAN
  OUTSIDE_WALKING_AREA
  DISTANCE_UNAVAILABLE
  ROUTING_PROVIDER_UNAVAILABLE
  NO_SLOTS_FOR_SELECTED_LOCATION
  INVENTORY_NOT_READY
  TRANSFER_REQUIRED
  QUOTE_EXPIRED
  CAPACITY_HOLD_FAILED
  POLICY_VERSION_UNAVAILABLE
  CONTACT_STORE
}

enum WalkingQuoteAssignmentRule {
  FIXED_POSTAL_ZONE
  NEAREST_WALKING_ROUTE
}

enum WalkingDistanceBasis {
  ONE_WAY_FROM_SELECTED_STORE
}

enum WalkingInventoryReadinessStatus {
  NOT_EVALUATED
  READY
  TRANSFER_REQUIRED
  NOT_READY
  UNAVAILABLE
}

enum InventoryTransferStatus {
  NOT_REQUIRED
  TRANSFER_REQUIRED
  REQUESTED
  IN_TRANSIT
  RECEIVED
  READY
  CANCELLED
  FAILED
}

enum WalkingCapacitySlotStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum WalkingCapacityHoldStatus {
  HELD
  CONFIRMED
  RELEASED
  EXPIRED
}

enum WalkingCapacityHoldReleaseReason {
  QUOTE_EXPIRED
  ORDER_CANCELLED
  PAYMENT_FAILED
  INVENTORY_UNAVAILABLE
  CAPACITY_UNAVAILABLE
  MANUAL
}

enum WalkingInventoryReservationStatus {
  HELD
  CONFIRMED
  RELEASED
  EXPIRED
}

enum WalkingInventoryReservationReleaseReason {
  QUOTE_EXPIRED
  ORDER_CANCELLED
  PAYMENT_FAILED
  INVENTORY_UNAVAILABLE
  CAPACITY_UNAVAILABLE
  MANUAL
}

model OperationalLocation {
  id                           String                               @id @default(uuid()) @db.Uuid
  code                         String                               @unique @db.VarChar(8)
  publicId                     String?                              @unique(map: "OperationalLocation_publicId_key") @db.VarChar(64)
  name                         String
  type                         LocationType
  active                       Boolean                              @default(true)
  addressLine1                 String?
  addressLine2                 String?
  city                         String?
  regionCode                   String?                              @db.VarChar(2)
  postalCode                   String?                              @db.VarChar(10)
  countryCode                  String?                              @db.Char(2)
  timeZone                     String?                              @db.VarChar(64)
  latitude                     Decimal?                             @db.Decimal(9, 6)
  longitude                    Decimal?                             @db.Decimal(9, 6)
  createdAt                    DateTime                             @default(now())
  updatedAt                    DateTime                             @updatedAt
  squareMappings               SquareLocationMapping[]
  userGrants                   UserLocationGrant[]
  ownedLots                    InventoryLot[]                       @relation("LotOwner")
  ownedContainers              Container[]                          @relation("ContainerOwner")
  storageAreas                 StorageLocation[]
  containers                   Container[]                          @relation("ContainerCurrentLocation")
  ledgerFrom                   InventoryLedgerEntry[]               @relation("LedgerFromLocation")
  ledgerTo                     InventoryLedgerEntry[]               @relation("LedgerToLocation")
  walkingZoneCandidates        WalkingZoneCandidate[]
  feePolicies                  FeePolicy[]
  slotPolicies                 SlotPolicy[]
  storeOnlineSourcePolicies    StoreOnlineFulfillmentPolicy[]       @relation("StoreOnlineSource")
  storeOnlineConsolidationHubs StoreOnlineFulfillmentPolicy[]       @relation("StoreOnlineConsolidation")
  walkingDeliveryQuotes        WalkingDeliveryQuote[]               @relation("WalkingQuoteSelectedLocation")
  localDeliveryIdentity        LocalDeliveryLocationIdentity?
  walkingCandidateRoutes       WalkingDeliveryQuoteCandidateRoute[]
  walkingCapacitySlots         WalkingCapacitySlot[]
  walkingInventoryOwnerLines   WalkingDeliveryQuoteInventoryLine[]  @relation("WalkingInventoryOwnerLocation")
  walkingInventoryNodeLines    WalkingDeliveryQuoteInventoryLine[]  @relation("WalkingInventoryNodeLocation")
  walkingReservationOrders     WalkingInventoryReservation[]        @relation("WalkingInventoryReservationOrderLocation")
  walkingReservationDeliveries WalkingInventoryReservation[]        @relation("WalkingInventoryReservationDeliveryLocation")
  walkingReservationOwnerLines WalkingInventoryReservationLine[]    @relation("WalkingInventoryReservationOwnerLocation")
  walkingReservationNodeLines  WalkingInventoryReservationLine[]    @relation("WalkingInventoryReservationNodeLocation")
  inventoryNodeBalancesOwned   InventoryNodeBalance[]               @relation("InventoryNodeBalanceOwnerLocation")
  inventoryNodeBalancesStored  InventoryNodeBalance[]               @relation("InventoryNodeBalanceNodeLocation")
}

model SquareLocationMapping {
  id                    String              @id @default(uuid()) @db.Uuid
  operationalLocationId String              @db.Uuid
  squareLocationId      String
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  verifiedByUserId      String?             @db.Uuid
  createdAt             DateTime            @default(now())
  operationalLocation   OperationalLocation @relation(fields: [operationalLocationId], references: [id], onDelete: Restrict)

  @@unique([squareLocationId, effectiveFrom])
  @@index([operationalLocationId, effectiveFrom])
}

model User {
  id                                  String                            @id @default(uuid()) @db.Uuid
  subject                             String                            @unique @db.Uuid
  email                               String                            @unique
  displayName                         String
  active                              Boolean                           @default(true)
  version                             Int                               @default(1)
  createdAt                           DateTime                          @default(now())
  updatedAt                           DateTime                          @updatedAt
  roles                               UserRole[]
  locations                           UserLocationGrant[]
  auditEvents                         AuditEvent[]
  walkingZonesCreated                 WalkingZone[]                     @relation("WalkingZoneCreatedBy")
  walkingZoneVersionsCreated          WalkingZoneVersion[]              @relation("WalkingZoneVersionCreatedBy")
  walkingZoneVersionsPublished        WalkingZoneVersion[]              @relation("WalkingZoneVersionPublishedBy")
  feePoliciesCreated                  FeePolicy[]                       @relation("FeePolicyCreatedBy")
  feePoliciesPublished                FeePolicy[]                       @relation("FeePolicyPublishedBy")
  slotPoliciesCreated                 SlotPolicy[]                      @relation("SlotPolicyCreatedBy")
  slotPoliciesPublished               SlotPolicy[]                      @relation("SlotPolicyPublishedBy")
  storeOnlinePoliciesCreated          StoreOnlineFulfillmentPolicy[]    @relation("StoreOnlinePolicyCreatedBy")
  storeOnlinePoliciesPublished        StoreOnlineFulfillmentPolicy[]    @relation("StoreOnlinePolicyPublishedBy")
  walkingPublicationsPublished        WalkingPublication[]              @relation("WalkingPublicationPublishedBy")
  feeCalculationPoliciesCreated       FeeCalculationPolicy[]            @relation("FeeCalculationPolicyCreatedBy")
  feeCalculationVersionsCreated       FeeCalculationPolicyVersion[]     @relation("FeeCalculationVersionCreatedBy")
  feeCalculationVersionsPublished     FeeCalculationPolicyVersion[]     @relation("FeeCalculationVersionPublishedBy")
  feeCalculationPublicationsPublished FeeCalculationPolicyPublication[] @relation("FeeCalculationPublicationPublishedBy")
  walkingDeliveryQuotesCreated        WalkingDeliveryQuote[]            @relation("WalkingQuoteCreatedBy")
  walkingZoneSetVersionsCreated       WalkingZoneSetVersion[]           @relation("WalkingZoneSetVersionCreatedBy")
  walkingZoneSetVersionsPublished     WalkingZoneSetVersion[]           @relation("WalkingZoneSetVersionPublishedBy")
  machineClientsOwned                 MachineClient[]                   @relation("MachineClientOwner")
  machineAuthorizationApprovals       MachineAuthorizationApproval[]    @relation("MachineAuthorizationApprovalApprovedBy")
  machineAuthorizationActivations     MachineAuthorizationActivation[]  @relation("MachineAuthorizationActivationActivatedBy")
}

model UserRole {
  userId    String   @db.Uuid
  role      RoleCode
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
}

model UserLocationGrant {
  userId     String              @db.Uuid
  locationId String              @db.Uuid
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   OperationalLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
}

model MachineClient {
  id          String                           @id @default(uuid()) @db.Uuid
  key         String                           @unique(map: "MachineClient_key_key") @db.VarChar(120)
  displayName String                           @db.VarChar(160)
  environment MachineEnvironment
  status      MachineAuthorizationStatus       @default(PENDING_VERIFICATION)
  ownerUserId String?                          @db.Uuid
  version     Int                              @default(1)
  activatedAt DateTime?                        @db.Timestamptz(6)
  suspendedAt DateTime?                        @db.Timestamptz(6)
  revokedAt   DateTime?                        @db.Timestamptz(6)
  createdAt   DateTime                         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime                         @updatedAt @db.Timestamptz(6)
  owner       User?                            @relation("MachineClientOwner", fields: [ownerUserId], references: [id], onDelete: Restrict, map: "MachineClient_owner_fkey")
  credentials MachineCredential[]
  grants      MachineClientGrant[]
  approvals   MachineAuthorizationApproval[]
  activations MachineAuthorizationActivation[]

  @@unique([id, environment], map: "MachineClient_id_environment_key")
  @@index([environment, status], map: "MachineClient_environment_status_idx")
  @@index([ownerUserId], map: "MachineClient_owner_idx")
}

model MachineCredential {
  id               String                           @id @default(uuid()) @db.Uuid
  machineClientId  String                           @db.Uuid
  environment      MachineEnvironment
  provider         MachineCredentialProvider
  issuer           String                           @db.VarChar(255)
  externalClientId String                           @db.VarChar(120)
  status           MachineAuthorizationStatus       @default(PENDING_VERIFICATION)
  version          Int                              @default(1)
  verifiedAt       DateTime?                        @db.Timestamptz(6)
  activatedAt      DateTime?                        @db.Timestamptz(6)
  suspendedAt      DateTime?                        @db.Timestamptz(6)
  revokedAt        DateTime?                        @db.Timestamptz(6)
  lastUsedAt       DateTime?                        @db.Timestamptz(6)
  createdAt        DateTime                         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime                         @updatedAt @db.Timestamptz(6)
  client           MachineClient                    @relation(fields: [machineClientId, environment], references: [id, environment], onDelete: Restrict, map: "MachineCredential_client_environment_fkey")
  approvals        MachineAuthorizationApproval[]
  activations      MachineAuthorizationActivation[]

  @@unique([provider, issuer, externalClientId], map: "MachineCredential_provider_issuer_external_key")
  @@index([machineClientId, environment, status], map: "MachineCredential_client_environment_status_idx")
}

model MachineClientGrant {
  machineClientId String                     @db.Uuid
  environment     MachineEnvironment
  scope           String                     @db.VarChar(100)
  status          MachineAuthorizationStatus @default(PENDING_VERIFICATION)
  version         Int                        @default(1)
  activatedAt     DateTime?                  @db.Timestamptz(6)
  suspendedAt     DateTime?                  @db.Timestamptz(6)
  revokedAt       DateTime?                  @db.Timestamptz(6)
  createdAt       DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @db.Timestamptz(6)
  client          MachineClient              @relation(fields: [machineClientId, environment], references: [id, environment], onDelete: Restrict, map: "MachineClientGrant_client_environment_fkey")

  @@id([machineClientId, environment, scope], map: "MachineClientGrant_pkey")
  @@index([environment, status, scope], map: "MachineClientGrant_environment_status_scope_idx")
}

model MachineAuthorizationApproval {
  id                                String                          @id @db.Uuid
  machineClientId                   String                          @db.Uuid
  environment                       MachineEnvironment
  credentialId                      String                          @db.Uuid
  approvedByUserId                  String                          @db.Uuid
  certificationAuditEventId         String                          @unique(map: "MachineAuthorizationApproval_certification_audit_key") @db.Uuid
  approvalAuditEventId              String                          @unique(map: "MachineAuthorizationApproval_approval_audit_key") @db.Uuid
  certificationCorrelationId        String                          @db.Uuid
  approvalCorrelationId             String                          @unique(map: "MachineAuthorizationApproval_approval_correlation_key") @db.Uuid
  certificationEvidenceDigestSha256 String                          @db.Char(64)
  clientVersion                     Int
  credentialVersion                 Int
  grantVersions                     Json
  reason                            String                          @db.VarChar(500)
  decision                          String                          @db.VarChar(40)
  approvalSourceCommitSha           String                          @db.VarChar(64)
  approvalSourceTreeSha             String                          @db.VarChar(64)
  approvalDigestSha256              String                          @unique(map: "MachineAuthorizationApproval_digest_key") @db.Char(64)
  approvedAt                        DateTime                        @default(now()) @db.Timestamptz(6)
  client                            MachineClient                   @relation(fields: [machineClientId, environment], references: [id, environment], onDelete: Restrict, map: "MachineAuthorizationApproval_client_environment_fkey")
  credential                        MachineCredential               @relation(fields: [credentialId], references: [id], onDelete: Restrict, map: "MachineAuthorizationApproval_credential_fkey")
  approvedBy                        User                            @relation("MachineAuthorizationApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: Restrict, map: "MachineAuthorizationApproval_approved_by_fkey")
  certificationAudit                AuditEvent                      @relation("MachineAuthorizationApprovalCertificationAudit", fields: [certificationAuditEventId], references: [id], onDelete: Restrict, map: "MachineAuthorizationApproval_certification_audit_fkey")
  approvalAudit                     AuditEvent                      @relation("MachineAuthorizationApprovalApprovalAudit", fields: [approvalAuditEventId], references: [id], onDelete: Restrict, map: "MachineAuthorizationApproval_approval_audit_fkey")
  activation                        MachineAuthorizationActivation?

  @@index([machineClientId, environment, approvedAt], map: "MachineAuthorizationApproval_client_environment_approved_idx")
  @@index([approvedByUserId, approvedAt], map: "MachineAuthorizationApproval_approved_by_idx")
}

model MachineAuthorizationActivation {
  id                        String                       @id @db.Uuid
  approvalId                String                       @unique(map: "MachineAuthorizationActivation_approval_key") @db.Uuid
  machineClientId           String                       @db.Uuid
  environment               MachineEnvironment
  credentialId              String                       @db.Uuid
  activatedByUserId         String                       @db.Uuid
  activationAuditEventId    String                       @unique(map: "MachineAuthorizationActivation_audit_key") @db.Uuid
  activationCorrelationId   String                       @unique(map: "MachineAuthorizationActivation_correlation_key") @db.Uuid
  approvalDigestSha256      String                       @db.Char(64)
  clientVersionBefore       Int
  credentialVersionBefore   Int
  grantVersionsBefore       Json
  clientVersionAfter        Int
  credentialVersionAfter    Int
  grantVersionsAfter        Json
  reason                    String                       @db.VarChar(500)
  activationSourceCommitSha String                       @db.VarChar(64)
  activationSourceTreeSha   String                       @db.VarChar(64)
  activationDigestSha256    String                       @unique(map: "MachineAuthorizationActivation_digest_key") @db.Char(64)
  activatedAt               DateTime                     @db.Timestamptz(6)
  approval                  MachineAuthorizationApproval @relation(fields: [approvalId], references: [id], onDelete: Restrict, map: "MachineAuthorizationActivation_approval_fkey")
  client                    MachineClient                @relation(fields: [machineClientId, environment], references: [id, environment], onDelete: Restrict, map: "MachineAuthorizationActivation_client_environment_fkey")
  credential                MachineCredential            @relation(fields: [credentialId], references: [id], onDelete: Restrict, map: "MachineAuthorizationActivation_credential_fkey")
  activatedBy               User                         @relation("MachineAuthorizationActivationActivatedBy", fields: [activatedByUserId], references: [id], onDelete: Restrict, map: "MachineAuthorizationActivation_activated_by_fkey")
  activationAudit           AuditEvent                   @relation("MachineAuthorizationActivationAudit", fields: [activationAuditEventId], references: [id], onDelete: Restrict, map: "MachineAuthorizationActivation_audit_fkey")

  @@index([machineClientId, environment, activatedAt], map: "MachineAuthorizationActivation_client_environment_activated_idx")
  @@index([activatedByUserId, activatedAt], map: "MachineAuthorizationActivation_activated_by_idx")
}

model IdempotencyRecord {
  id             String    @id @default(uuid()) @db.Uuid
  scope          String
  key            String
  requestHash    String
  responseStatus Int?
  responseBody   Json?
  lockedUntil    DateTime?
  completedAt    DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@unique([scope, key])
  @@index([expiresAt])
}

model WebhookInbox {
  id            String        @id @default(uuid()) @db.Uuid
  provider      String
  externalId    String
  eventType     String
  payload       Json
  payloadHash   String
  status        MessageStatus @default(PENDING)
  attemptCount  Int           @default(0)
  nextAttemptAt DateTime      @default(now())
  processedAt   DateTime?
  lastErrorCode String?
  receivedAt    DateTime      @default(now())

  @@unique([provider, externalId])
  @@index([status, nextAttemptAt])
}

model OutboxMessage {
  id            String        @id @default(uuid()) @db.Uuid
  topic         String
  aggregateType String
  aggregateId   String
  payload       Json
  status        MessageStatus @default(PENDING)
  attemptCount  Int           @default(0)
  nextAttemptAt DateTime      @default(now())
  processedAt   DateTime?
  lastErrorCode String?
  createdAt     DateTime      @default(now())

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String
  rules       Json?
  updatedAt   DateTime @updatedAt
}

model AuditEvent {
  id                                 String                           @id @default(uuid()) @db.Uuid
  actorId                            String?                          @db.Uuid
  action                             String
  entityType                         String
  entityId                           String?
  locationCode                       String?
  correlationId                      String
  reason                             String?
  before                             Json?
  after                              Json?
  occurredAt                         DateTime                         @default(now()) @db.Timestamp(6)
  actor                              User?                            @relation(fields: [actorId], references: [id], onDelete: SetNull)
  machineAuthorizationCertifications MachineAuthorizationApproval[]   @relation("MachineAuthorizationApprovalCertificationAudit")
  machineAuthorizationApprovals      MachineAuthorizationApproval[]   @relation("MachineAuthorizationApprovalApprovalAudit")
  machineAuthorizationActivations    MachineAuthorizationActivation[] @relation("MachineAuthorizationActivationAudit")

  @@index([entityType, entityId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([correlationId])
}

model Product {
  id                               String                              @id @default(uuid()) @db.Uuid
  squareVariationId                String                              @unique
  displayName                      String
  active                           Boolean                             @default(true)
  createdAt                        DateTime                            @default(now())
  updatedAt                        DateTime                            @updatedAt
  identifiers                      ProductIdentifier[]
  lots                             InventoryLot[]
  manifestLines                    ManifestLine[]
  ledgerEntries                    InventoryLedgerEntry[]
  containerBalances                ContainerContentProjection[]
  walkingQuoteInventoryLines       WalkingDeliveryQuoteInventoryLine[]
  walkingInventoryReservationLines WalkingInventoryReservationLine[]
  inventoryNodeBalances            InventoryNodeBalance[]
}

model ProductIdentifier {
  id              String                @id @default(uuid()) @db.Uuid
  productId       String                @db.Uuid
  type            ProductIdentifierType
  normalizedValue String
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  product         Product               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([type, normalizedValue])
  @@index([productId])
}

model StorageLocation {
  id                               String                              @id @default(uuid()) @db.Uuid
  operationalLocationId            String                              @db.Uuid
  code                             String
  name                             String
  active                           Boolean                             @default(true)
  pickSequence                     Int?
  maxContainerCount                Int?
  createdAt                        DateTime                            @default(now())
  updatedAt                        DateTime                            @updatedAt
  operationalLocation              OperationalLocation                 @relation(fields: [operationalLocationId], references: [id], onDelete: Restrict)
  containers                       Container[]
  ledgerFrom                       InventoryLedgerEntry[]              @relation("LedgerFromStorage")
  ledgerTo                         InventoryLedgerEntry[]              @relation("LedgerToStorage")
  walkingQuoteInventoryLines       WalkingDeliveryQuoteInventoryLine[]
  walkingInventoryReservationLines WalkingInventoryReservationLine[]
  inventoryNodeBalances            InventoryNodeBalance[]

  @@unique([operationalLocationId, code])
  @@index([operationalLocationId, active])
}

model InventoryLot {
  id                               String                            @id @default(uuid()) @db.Uuid
  productId                        String                            @db.Uuid
  ownerLocationId                  String                            @db.Uuid
  sourceReference                  String?
  seasonCode                       String?
  receivedAt                       DateTime?
  createdAt                        DateTime                          @default(now())
  product                          Product                           @relation(fields: [productId], references: [id], onDelete: Restrict)
  ownerLocation                    OperationalLocation               @relation("LotOwner", fields: [ownerLocationId], references: [id], onDelete: Restrict)
  manifestLines                    ManifestLine[]
  ledgerEntries                    InventoryLedgerEntry[]
  containerBalances                ContainerContentProjection[]
  walkingInventoryReservationLines WalkingInventoryReservationLine[]
  inventoryNodeBalances            InventoryNodeBalance[]

  @@index([productId, ownerLocationId])
  @@index([ownerLocationId, seasonCode])
}

model Container {
  id                               String                              @id @default(uuid()) @db.Uuid
  code                             String                              @unique @db.VarChar(16)
  type                             ContainerType
  status                           ContainerStatus                     @default(OPEN)
  ownerLocationId                  String                              @db.Uuid
  currentLocationId                String                              @db.Uuid
  storageLocationId                String?                             @db.Uuid
  version                          Int                                 @default(1)
  createdAt                        DateTime                            @default(now())
  updatedAt                        DateTime                            @updatedAt
  ownerLocation                    OperationalLocation                 @relation("ContainerOwner", fields: [ownerLocationId], references: [id], onDelete: Restrict)
  currentLocation                  OperationalLocation                 @relation("ContainerCurrentLocation", fields: [currentLocationId], references: [id], onDelete: Restrict)

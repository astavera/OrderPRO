model WalkingCapacitySlot {
  id                    String                    @id @default(uuid()) @db.Uuid
  slotPolicyId          String                    @db.Uuid
  operationalLocationId String                    @db.Uuid
  slotKey               String                    @db.VarChar(160)
  startsAt              DateTime
  endsAt                DateTime
  capacitySeconds       Int
  status                WalkingCapacitySlotStatus @default(OPEN)
  version               Int                       @default(1)
  createdAt             DateTime                  @default(now())

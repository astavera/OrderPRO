  storageLocation          StorageLocation?            @relation(fields: [storageLocationId], references: [id], onDelete: Restrict, map: "WalkingInventoryReservationLine_storage_location_fkey")

  @@unique([reservationId, lineNumber], map: "WalkingInventoryReservationLine_reservation_line_key")
  @@index([inventoryNodeBalanceId], map: "WalkingInventoryReservationLine_balance_idx")
  @@index([containerId, inventoryLotId], map: "WalkingInventoryReservationLine_container_lot_idx")
  @@index([inventoryNodeId, productId], map: "WalkingInventoryReservationLine_node_product_idx")
}

  @@index([feePolicyVersionId], map: "FeeCalculationPublication_version_idx")
  @@index([status, effectiveFrom, effectiveTo], map: "FeeCalculationPublication_status_effective_idx")
  @@index([digest], map: "FeeCalculationPublication_digest_idx")
}

model WalkingDeliveryQuote {
  id                                String                               @id @default(uuid()) @db.Uuid
  schemaVersion                     String                               @default("orderpro.walking-delivery-quote.v1") @db.VarChar(100)
  clientId                          String                               @db.VarChar(120)
  idempotencyKey                    String                               @db.VarChar(160)
  requestHash                       String                               @db.VarChar(80)
  normalizedAddress                 String?
  normalizedAddressStructured       Json?
  customerCoordinates               Json?
  postalCode                        String?                              @db.VarChar(10)
  selectedLocationId                String?                              @db.VarChar(64)
  externalSelectedLocationId        String?                              @db.VarChar(64)
  selectedOperationalLocationId     String?                              @db.Uuid
  selectedLocalDeliveryLocationId   String?                              @db.Uuid
  zoneVersionId                     String?                              @db.Uuid
  zoneSetVersionId                  String?                              @db.Uuid
  externalZoneVersionId             String?                              @db.VarChar(120)
  feePolicyVersionId                String?                              @db.Uuid
  externalFeePolicyVersionId        String?                              @db.VarChar(120)
  assignmentRule                    WalkingQuoteAssignmentRule?
  routingProvider                   String?                              @db.VarChar(80)
  routingProfile                    String                               @default("walking") @db.VarChar(32)
  distanceBasis                     WalkingDistanceBasis?
  distanceFeet                      Decimal?                             @db.Decimal(12, 2)
  durationSeconds                   Int?
  roundTripDistanceFeet             Decimal?                             @db.Decimal(12, 2)
  estimatedRoundTripDurationSeconds Int?
  preparationBufferSeconds          Int?                                 @default(0)
  handoffBufferSeconds              Int?                                 @default(0)
  capacityRequiredSeconds           Int?
  feeCents                          Int?
  currency                          String?                              @db.Char(3)
  bookable                          Boolean?
  tierId                            String?                              @db.Uuid
  reasonCode                        WalkingQuoteReasonCodeV4
  calculatedAt                      DateTime
  routeCalculatedAt                 DateTime?
  expiresAt                         DateTime?
  inventoryReadinessStatus          WalkingInventoryReadinessStatus      @default(NOT_EVALUATED)
  inventoryReadyAt                  DateTime?
  feePolicySnapshot                 Json?
  tierSnapshot                      Json?
  slotPolicyId                      String?                              @db.Uuid
  slotSnapshot                      Json?
  walkingPublicationId              String?                              @db.Uuid
  correlationId                     String                               @db.VarChar(120)
  createdById                       String?                              @db.Uuid
  createdAt                         DateTime                             @default(now())
  selectedOperationalLocation       OperationalLocation?                 @relation("WalkingQuoteSelectedLocation", fields: [selectedOperationalLocationId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_location_fkey")
  selectedLocalDeliveryLocation     LocalDeliveryLocationIdentity?       @relation(fields: [selectedLocalDeliveryLocationId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_local_delivery_location_fkey")
  zoneVersion                       WalkingZoneVersion?                  @relation(fields: [zoneVersionId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_zone_version_fkey")
  zoneSetVersion                    WalkingZoneSetVersion?               @relation(fields: [zoneSetVersionId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_zone_set_version_fkey")
  feePolicyVersion                  FeeCalculationPolicyVersion?         @relation(fields: [feePolicyVersionId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_fee_version_fkey")
  tier                              FeeCalculationTier?                  @relation(fields: [tierId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_tier_fkey")
  slotPolicy                        SlotPolicy?                          @relation(fields: [slotPolicyId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_slot_policy_fkey")
  walkingPublication                WalkingPublication?                  @relation(fields: [walkingPublicationId], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_publication_fkey")
  createdBy                         User?                                @relation("WalkingQuoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, map: "WalkingDeliveryQuote_created_by_fkey")
  candidateRoutes                   WalkingDeliveryQuoteCandidateRoute[]
  inventoryLines                    WalkingDeliveryQuoteInventoryLine[]
  capacityHolds                     WalkingCapacityHold[]
  inventoryReservations             WalkingInventoryReservation[]

  @@unique([clientId, idempotencyKey], map: "WalkingDeliveryQuote_client_idempotency_key")
  @@index([selectedLocationId, calculatedAt], map: "WalkingDeliveryQuote_location_calculated_idx")
  @@index([selectedOperationalLocationId], map: "WalkingDeliveryQuote_operational_location_idx")
  @@index([zoneVersionId, calculatedAt], map: "WalkingDeliveryQuote_zone_calculated_idx")
  @@index([feePolicyVersionId, calculatedAt], map: "WalkingDeliveryQuote_fee_version_calculated_idx")
  @@index([postalCode, calculatedAt], map: "WalkingDeliveryQuote_postal_calculated_idx")
  @@index([reasonCode, calculatedAt], map: "WalkingDeliveryQuote_reason_calculated_idx")
  @@index([correlationId], map: "WalkingDeliveryQuote_correlation_idx")
  @@index([requestHash], map: "WalkingDeliveryQuote_request_hash_idx")
  @@index([externalZoneVersionId, calculatedAt], map: "WalkingDeliveryQuote_external_zone_version_idx")
  @@index([externalFeePolicyVersionId, calculatedAt], map: "WalkingDeliveryQuote_external_fee_version_idx")
  @@index([expiresAt], map: "WalkingDeliveryQuote_expiry_idx")
}

model WalkingDeliveryQuoteCandidateRoute {
  id                      String                        @id @default(uuid()) @db.Uuid
  quoteId                 String                        @db.Uuid
  localDeliveryLocationId String                        @db.Uuid
  operationalLocationId   String                        @db.Uuid
  externalLocationId      String                        @db.VarChar(64)
  sequence                Int
  locationPriority        Int?
  walkingDistanceFeet     Decimal                       @db.Decimal(12, 2)
  walkingDurationSeconds  Int
  routingProvider         String                        @db.VarChar(80)
  routingProfile          String                        @default("walking") @db.VarChar(32)
  routeCalculatedAt       DateTime
  selected                Boolean                       @default(false)
  createdAt               DateTime                      @default(now())
  quote                   WalkingDeliveryQuote          @relation(fields: [quoteId], references: [id], onDelete: Restrict, map: "WalkingQuoteCandidateRoute_quote_fkey")
  localDeliveryLocation   LocalDeliveryLocationIdentity @relation(fields: [localDeliveryLocationId], references: [id], onDelete: Restrict, map: "WalkingQuoteCandidateRoute_local_identity_fkey")
  operationalLocation     OperationalLocation           @relation(fields: [operationalLocationId], references: [id], onDelete: Restrict, map: "WalkingQuoteCandidateRoute_location_fkey")

  @@unique([quoteId, operationalLocationId], map: "WalkingQuoteCandidateRoute_quote_location_key")
  @@unique([quoteId, sequence], map: "WalkingQuoteCandidateRoute_quote_sequence_key")
  @@index([quoteId, selected], map: "WalkingQuoteCandidateRoute_quote_selected_idx")
}


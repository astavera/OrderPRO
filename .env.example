# Supabase Shared Pooler transaction-mode URL for application runtime (port 6543).
# Keep pgbouncer=true because transaction pooling does not support prepared statements.
DATABASE_URL="postgresql://postgres.vzuibvzwodrhryphkqjz:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Shared Pooler session-mode URL for migrations (port 5432).
DIRECT_URL="postgresql://postgres.vzuibvzwodrhryphkqjz:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Hard safety gate. The application schema accepts only false until Square certification.
ORDERPRO_SQUARE_WRITES_ENABLED="false"


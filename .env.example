# Supabase Shared Pooler transaction-mode URL for application runtime (port 6543).
# Keep pgbouncer=true because transaction pooling does not support prepared statements.
DATABASE_URL="postgresql://postgres.vzuibvzwodrhryphkqjz:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Shared Pooler session-mode URL for migrations (port 5432).
DIRECT_URL="postgresql://postgres.vzuibvzwodrhryphkqjz:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Hard safety gate. The application schema accepts only false until Square certification.
ORDERPRO_SQUARE_WRITES_ENABLED="false"

# Hard runtime gate for Local Walking Delivery V4. Keep false until the
# all-or-nothing STAGING readiness review approves M2M and every provider.
ORDERPRO_LOCAL_DELIVERY_V4_API_ENABLED="false"
ORDERPRO_RUNTIME_ENVIRONMENT="STAGING"

# Auth0 M2M resource-server configuration for the STAGING pilot. These values
# remain disabled until the pending client/grants and every provider are certified.
# Never add an Auth0 Client Secret, access token or Management API token here.
ORDERPRO_M2M_AUTH_MODE="DISABLED"
ORDERPRO_M2M_ISSUER=""
ORDERPRO_M2M_AUDIENCE=""
ORDERPRO_M2M_JWKS_URI=""
ORDERPRO_M2M_ALLOWED_ALGORITHM="RS256"

NEXT_PUBLIC_SUPABASE_URL="https://vzuibvzwodrhryphkqjz.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="[YOUR-PUBLISHABLE-KEY]"

# Server-only key used exclusively for Supabase Auth administration. Never use
# NEXT_PUBLIC_ or expose this value to the browser. Prefer the current sb_secret_ key.
SUPABASE_SECRET_KEY="[YOUR-SECRET-KEY]"

# Canonical origin used in invitation emails. Production must use HTTPS.
ORDERPRO_APP_URL="http://localhost:3001"
